generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  metaDesc  String?
  updatedAt DateTime @updatedAt
}

model Post {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String
  excerpt     String?
  youtubeUrl  String?
  category    PostCategory
  published   Boolean      @default(false)
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  mediaItems  Media[]
}

enum PostCategory {
  DHARMA_GEM
  TALK
  DANCE_ARTICLE
  DANCE_INTERVIEW
  ORIGINAL_DANCE
  RESOURCE
}

model Event {
  id                   String              @id @default(cuid())
  title                String
  slug                 String              @unique
  description          String
  startDate            DateTime
  endDate              DateTime?
  location             String?
  isOnline             Boolean             @default(false)
  isRetreat            Boolean             @default(false)
  registerUrl          String?
  flyerUrl             String?
  featuredImageUrl     String?
  featured             Boolean             @default(false)
  published            Boolean             @default(false)
  createdAt            DateTime            @default(now())

  // Built-in registration
  registrationEnabled  Boolean             @default(false)
  capacity             Int?
  // Pricing (all amounts in cents). FIXED uses priceMin as the price;
  // SLIDING uses priceMin–priceMax. Early bird applies until its deadline.
  pricingType          PricingType         @default(FREE)
  priceMin             Int?
  priceMax             Int?
  earlyBirdPriceMin    Int?
  earlyBirdPriceMax    Int?
  earlyBirdDeadline    DateTime?
  registrationDeadline DateTime?
  registrations        EventRegistration[]
}

enum PricingType {
  FREE
  FIXED
  SLIDING
}

model EventRegistration {
  id        String             @id @default(cuid())
  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String
  name      String
  email     String
  phone     String?
  dietary   String?
  notes     String?
  status    RegistrationStatus @default(PENDING)
  checkedIn Boolean            @default(false)
  room      Room?              @relation(fields: [roomId], references: [id], onDelete: SetNull)
  roomId    String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Room {
  id            String              @id @default(cuid())
  name          String              @unique
  capacity      Int?
  order         Int                 @default(0)
  registrations EventRegistration[]
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  WAITLISTED
  CANCELLED
}

model Album {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  coverUrl    String?
  year        Int?
  buyUrl      String?
  tracks      Track[]
  published   Boolean @default(false)
}

model Track {
  id       String  @id @default(cuid())
  title    String
  duration Int?
  audioUrl String?
  order    Int
  album    Album   @relation(fields: [albumId], references: [id], onDelete: Cascade)
  albumId  String
}

model MusicVideo {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String?
  youtubeUrl   String?
  thumbnailUrl String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Teacher {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  bio       String
  photoUrl  String?
  order     Int     @default(0)
  published Boolean @default(true)
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
}

// Mureed Directory, self-submitted listings behind the Mureeds' Corner gate
model MureedProfile {
  id        String   @id @default(cuid())
  name      String
  location  String
  email     String
  phone     String?
  photoUrl  String?
  createdAt DateTime @default(now())
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
  post      Post?    @relation(fields: [postId], references: [id])
  postId    String?
}
