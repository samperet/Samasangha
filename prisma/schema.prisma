generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  metaDesc  String?
  updatedAt DateTime @updatedAt
}

model Post {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String
  excerpt     String?
  youtubeUrl  String?
  category    PostCategory
  published   Boolean      @default(false)
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  mediaItems  Media[]
}

enum PostCategory {
  DHARMA_GEM
  TALK
  DANCE_ARTICLE
  DANCE_INTERVIEW
  ORIGINAL_DANCE
  RESOURCE
}

model Event {
  id                   String              @id @default(cuid())
  title                String
  slug                 String              @unique
  description          String
  startDate            DateTime
  endDate              DateTime?
  location             String?
  isOnline             Boolean             @default(false)
  isRetreat            Boolean             @default(false)
  registerUrl          String?
  flyerUrl             String?
  featuredImageUrl     String?
  featured             Boolean             @default(false)
  published            Boolean             @default(false)
  createdAt            DateTime            @default(now())

  // Built-in registration
  registrationEnabled  Boolean             @default(false)
  capacity             Int?
  // Pricing (all amounts in cents). FIXED uses priceMin as the price;
  // SLIDING uses priceMin–priceMax. Early bird applies until its deadline.
  pricingType          PricingType         @default(FREE)
  priceMin             Int?
  priceMax             Int?
  earlyBirdPriceMin    Int?
  earlyBirdPriceMax    Int?
  earlyBirdDeadline    DateTime?
  // Percent discount applied to the price for kids 18 and under (0–100).
  kidsDiscountPercent  Int?
  registrationDeadline DateTime?
  registrations        EventRegistration[]
  bookings             Booking[]
}

enum PricingType {
  FREE
  FIXED
  SLIDING
}

// A single checkout: one contact paying for one or more participants.
model Booking {
  id            String              @id @default(cuid())
  event         Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId       String
  name          String // lead contact
  email         String
  phone         String?
  notes         String?
  status        RegistrationStatus  @default(PENDING)
  paymentMethod PaymentMethod       @default(NONE)
  paymentStatus PaymentStatus       @default(UNPAID)
  amountCents   Int                 @default(0)
  paypalOrderId String?
  participants  EventRegistration[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

enum PaymentMethod {
  NONE
  PAYPAL
  CHECK
}

enum PaymentStatus {
  UNPAID
  PAID
}

model EventRegistration {
  id        String             @id @default(cuid())
  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String
  booking   Booking?           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String?
  name      String
  email     String
  phone     String?
  dietary   String?
  notes     String?
  isChild   Boolean            @default(false)
  status    RegistrationStatus @default(PENDING)
  checkedIn Boolean            @default(false)
  room      Room?              @relation(fields: [roomId], references: [id], onDelete: SetNull)
  roomId    String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Room {
  id            String              @id @default(cuid())
  name          String              @unique
  capacity      Int?
  order         Int                 @default(0)
  registrations EventRegistration[]
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  WAITLISTED
  CANCELLED
}

model Album {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  coverUrl    String?
  year        Int?
  buyUrl      String?
  tracks      Track[]
  published   Boolean @default(false)
}

model Track {
  id       String  @id @default(cuid())
  title    String
  duration Int?
  audioUrl String?
  order    Int
  album    Album   @relation(fields: [albumId], references: [id], onDelete: Cascade)
  albumId  String
}

model MusicVideo {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String?
  youtubeUrl   String?
  thumbnailUrl String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Teacher {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  bio       String
  photoUrl  String?
  order     Int     @default(0)
  published Boolean @default(true)
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
}

// Mureed Directory, self-submitted listings behind the Mureeds' Corner gate
model MureedProfile {
  id        String   @id @default(cuid())
  name      String
  location  String
  email     String
  phone     String?
  photoUrl  String?
  createdAt DateTime @default(now())
}

// Dismissible pop-up announcements shown on specific public pages within a
// scheduled time window.
model Notification {
  id         String           @id @default(cuid())
  message    String
  page       NotificationPage
  startTime  DateTime?
  finishTime DateTime?
  enabled    Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

enum NotificationPage {
  HOMEPAGE
  TUESDAY
  DANCES
  MUREEDS
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
  post      Post?    @relation(fields: [postId], references: [id])
  postId    String?
}

// Crowd-sourced voice recordings for the Loka Samasta collective song.
model LokaRecording {
  id         String    @id @default(cuid())
  name       String
  email      String
  voiceType  VoiceType
  audioUrl   String
  mimeType   String?
  durationMs Int?
  // Milliseconds the take should be delayed on playback to line up with the
  // backing track (compensates for the recorder's start-up gap).
  offsetMs   Int       @default(0)
  // Position in the backing track (ms) where this take began — 0 from the
  // start, or the vocals-start point when the singer used "skip to chanting".
  startMs    Int       @default(0)
  approved   Boolean   @default(false)
  createdAt  DateTime  @default(now())
}

enum VoiceType {
  LOWER
  HIGHER
}

// Singleton (id = "default") holding editable colors for the homepage's two
// coloured bands: the purple "Regular gatherings" section and the green
// "Retreats" section. Each can be a solid colour or a two-stop gradient.
model SiteDesign {
  id         String   @id @default("default")
  purpleType String   @default("gradient") // "solid" | "gradient"
  purpleFrom String   @default("#6b4a76")
  purpleTo   String   @default("#4d3155")
  greenType  String   @default("solid")
  greenFrom  String   @default("#fbf7ec")
  greenTo    String   @default("#e8efe0")
  footerType String   @default("gradient")
  footerFrom String   @default("#0a7d12")
  footerTo   String   @default("#024c06")
  updatedAt  DateTime @updatedAt
}
