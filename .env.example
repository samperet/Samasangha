DATABASE_URL="postgresql://localhost:5432/samasanga?schema=public"

# Admin sign-in: the single site password, plus a secret to sign session cookies
ADMIN_PASSWORD="choose-a-strong-password"
ADMIN_SESSION_SECRET="generate-with-openssl-rand-base64-32"

# Mureeds Deepening page password
DEEPENING_PASSWORD="AHHA"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@samasangha.org"
EMAIL_TO="admin@samasangha.org"

# File storage: "local" for dev (writes to /public/uploads), "r2" for production.
# Vercel's filesystem is read-only at runtime, so production MUST use r2.
STORAGE_PROVIDER="local"

# Cloudflare R2 (only needed when STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public base URL of the bucket, no trailing slash — e.g. https://media.samasangha.org
# or the r2.dev dev URL. Its hostname is auto-allowlisted for next/image (see next.config.ts).
R2_PUBLIC_URL=""
