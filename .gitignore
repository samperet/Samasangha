# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
/public/uploads

# music audio files (large; re-download via prisma/seed-albums.ts sources — see public/music/README.md)
/public/music/*
!/public/music/covers
!/public/music/README.md

# Dev scratch materials (not part of the site)
/Inspiration/
*.zip

# DB migration helper (contains prod credentials — never commit)
migrate-to-neon.sh
samasangha.sql
